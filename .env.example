# Copy to .env and fill in real values. Never commit the real .env file.

# --- Database ---
DATABASE_URL=postgresql+asyncpg://anku:anku@localhost:5432/anku

# --- Cache / broker ---
REDIS_URL=redis://localhost:6379/0

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string

# --- AI model providers (LiteLLM gateway) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=

# --- Git / deployment integrations ---
GITHUB_TOKEN=
VERCEL_TOKEN=
RAILWAY_TOKEN=

# --- Runtime ---
# Absolute path on the host where user project files are stored/mounted.
PROJECTS_ROOT=./projects_root
